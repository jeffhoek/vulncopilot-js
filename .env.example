# Copy to `.env.local` and fill in. NEVER commit real secrets.
# List values (ALLOWED_*, ACTION_BUTTONS, ADMIN_USER_IDENTIFIERS) are JSON arrays,
# NOT comma-separated — a bare `a@x.com,b@y.com` will fail zod validation on boot.

# ── API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key            # used for embeddings (text-embedding-3-small)

# ── PostgreSQL (shared with the Python ETL repo) ──────────────────────────
# This app is READ-MOSTLY: it does not create schema. The Python ETL side owns DDL.
# Point this at the same database the ETL pipeline populates.
PG_DATABASE_URL=postgresql://appuser:apppw@localhost:5432/inventory
# Managed Postgres (e.g. Timescale/Supabase) — append sslmode=require
# PG_DATABASE_URL=postgresql://user:pw@host:5432/dbname?sslmode=require

# ── RAG (optional — sane defaults) ────────────────────────────────────────
# TOP_K=5
# MAX_HISTORY_MESSAGES=50
# Pinned — must match the vectors already stored by the ETL side. Do not change
# without re-embedding the whole corpus.
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-sonnet-5
# Anthropic effort: low | medium | high | max. "low" suits short scoped lookups and
# avoids the ~4x latency of adaptive thinking. Leave blank for models without effort.
LLM_EFFORT=low
# SYSTEM_PROMPT overrides the built-in prompt. The built-in prompt embeds the full DB
# schema (tables, columns, JOIN guidance) the SQL tool depends on — if you override it,
# include that schema context or query quality degrades badly. See src/mastra/agents.
# SYSTEM_PROMPT=

# Quick-query button labels shown in the chat UI (JSON array).
# ACTION_BUTTONS=["List the 10 newest KEV entries by date_added","List KEV entries with known ransomware use","CVE-2021-44228 (Log4Shell)","Top vendors in KEV","Which weakness types appear most in KEV?"]

# ── Auth — GitHub OAuth (NextAuth / Auth.js) ──────────────────────────────
# Create an OAuth App at github.com/settings/developers.
# Callback URL: https://your-domain/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Required by NextAuth to sign session cookies. Generate: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Public origin of the app (NextAuth uses it to build callback URLs).
# AUTH_URL=http://localhost:3000
# Self-hosted (Docker/non-Vercel) deploys behind a proxy MUST set this or NextAuth
# rejects requests with "UntrustedHost". Leave unset for local `pnpm dev`.
# AUTH_TRUST_HOST=true

# ── Authorization (allow-list; JSON arrays) ───────────────────────────────
OPEN_REGISTRATION=false                         # true = any GitHub user allowed
# ALLOWED_EMAILS=["alice@example.com"]
# ALLOWED_EMAIL_DOMAINS=["mycompany.com"]
# ALLOWED_LOGINS=["jeffhoek"]                    # GitHub usernames

# ── Rate limiting (per user per UTC day, counted in Postgres user_usage) ───
DAILY_QUERY_LIMIT=20
ADMIN_DAILY_QUERY_LIMIT=100000
# Stable GitHub numeric ids (github:<id>) that get the elevated cap AND access to /admin.
# ADMIN_USER_IDENTIFIERS=["github:12345678"]

# Token prices for the /admin cost estimate (USD per million tokens).
LLM_INPUT_COST_PER_MILLION=3.00
LLM_OUTPUT_COST_PER_MILLION=15.00

# ── MCP server ────────────────────────────────────────────────────────────
# Guards /api/mcp via the x-api-key header. If unset, the endpoint is UNAUTHENTICATED —
# set this before deploying. Generate: openssl rand -hex 32
MCP_API_KEY=

# ── Observability — Langfuse (optional) ───────────────────────────────────
# Mastra AI tracing via the native @mastra/langfuse exporter. Tracing turns on
# ONLY when BOTH keys below are set — leave them blank for trace-free local dev.
# Setup + testing runbook: docs/observability-langfuse.md
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# Ingestion host — MUST match the region your keys were issued in. Langfuse Cloud
# is region-scoped: US (default) = https://us.cloud.langfuse.com, EU =
# https://eu.cloud.langfuse.com. The legacy https://cloud.langfuse.com 401s for
# region-scoped accounts. A region mismatch shows as "401 ... confirm the correct host".
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# Flush each span immediately (default true — safe for Cloud Run scale-to-zero,
# where a batched flush can be dropped when the instance is frozen after a
# response). Set false only with CPU always-allocated / a persistent server.
# LANGFUSE_REALTIME=true
# Raise exporter logging to debug to diagnose missing/stopped traces (noisy).
# LANGFUSE_DEBUG=false
